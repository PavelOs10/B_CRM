# ====================================================
# BarberCRM v5.0 — Все настройки приложения
# ====================================================
# Скопируйте этот файл: cp .env.example .env
# Заполните значения и запустите: bash deploy.sh
# ====================================================

# ---------- АДМИНИСТРАТОР CRM ----------
# Логин и пароль для входа в админ-панель
# (админ видит все филиалы, все данные)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=сюда_сильный_пароль

# ---------- ПОЧТА (SMTP) ----------
# Собственный почтовый сервер для отправки отчётов
# Если почта не нужна — оставьте пустым, CRM будет работать без неё
SMTP_HOST=mail.yourdomain.com
SMTP_PORT=587
SMTP_USER=crm@yourdomain.com
SMTP_PASSWORD=пароль_от_почты
# true = SSL (порт 465), false = STARTTLS (порт 587)
SMTP_USE_SSL=false
# Кому отправлять отчёты (email получателя)
REPORT_EMAIL_TO=boss@yourdomain.com

# ---------- TELEGRAM-БОТ ----------
# Токен от @BotFather
TELEGRAM_BOT_TOKEN=123456789:ABCDefGhIJKlmNoPQRsTUVwxyz
# Пароль для входа в бота (пустое = без пароля)
BOT_ACCESS_PASSWORD=
